{
  "name": "ElectronWebtoon",
  "productName": "ElectronWebtoon",
  "version": "2.4.6",
  "description": "Electron Webtoon 漫画阅读器",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder --publish never",
    "postinstall": "electron-builder install-app-deps",
    "lint": "echo skip",
    "test": "jest"
  },
  "build": {
    "productName": "ElectronWebtoon",
    "appId": "org.erb.ElectronWebtoon",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/libarchive-wasm/**"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "extraResources": [
      "./assets/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "Qquanwei",
      "repo": "electron-webtoon"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Qquanwei/electron-webtoon"
  },
  "author": {
    "name": "Qquanwei",
    "email": "quanwei9958@126.com",
    "url": "https://github.com/Qquanwei/electron-webtoon"
  },
  "contributors": [
    {
      "name": "Qquanwei",
      "email": "quanwei9958@126.com",
      "url": "https://github.com/Qquanwei/electron-webtoon"
    }
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Qquanwei/electron-webtoon"
  },
  "keywords": [
    "electron",
    "webtoon",
    "comic"
  ],
  "homepage": "https://github.com/Qquanwei/electron-webtoon",
  "jest": {
    "testURL": "http://localhost/",
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/test/mocks/fileMock.js",
      "\\.(css|less|sass|scss)$": "identity-obj-proxy"
    },
    "moduleFileExtensions": [
      "js",
      "jsx",
      "ts",
      "tsx",
      "json"
    ],
    "moduleDirectories": [
      "node_modules"
    ],
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": "babel-jest"
    }
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.26.0",
    "@babel/preset-typescript": "^7.26.0",
    "@testing-library/jest-dom": "^5.11.6",
    "@testing-library/react": "^11.2.2",
    "@types/jest": "^26.0.15",
    "@types/node": "^22.12.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-router-dom": "^5.1.6",
    "@vitejs/plugin-react": "^4.3.4",
    "babel-jest": "^26.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^26.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.0",
    "@koa/cors": "^3.1.0",
    "@mui/icons-material": "^5.16.14",
    "@mui/material": "^5.16.14",
    "libarchive-wasm": "^1.2.0",
    "classnames": "^2.3.1",
    "electron-debug": "^3.1.0",
    "electron-log": "^4.4.3",
    "electron-store": "^8.0.1",
    "electron-updater": "6.3.9",
    "frameless-titlebar": "^2.1.4",
    "history": "^5.0.0",
    "image-size": "^1.0.1",
    "is-electron": "^2.2.1",
    "koa": "^2.13.1",
    "koa-bodyparser": "^4.3.0",
    "koa-router": "^10.0.0",
    "koa-static": "^5.0.0",
    "lodash.shuffle": "^4.2.0",
    "mime-types": "^2.1.31",
    "network": "^0.6.0",
    "nzh": "^1.0.8",
    "qrcode-generator": "^1.4.4",
    "ramda": "^0.27.1",
    "react": "18.3.0",
    "react-dom": "18.3.0",
    "react-loading": "^2.0.3",
    "react-router-dom": "^5.2.0",
    "recoil": "^0.5.2",
    "recoil-enhance": "^0.0.3",
    "source-map-support": "^0.5.19",
    "tiny-event-manager": "^2.0.1",
    "uuid": "^8.3.2"
  }
}
